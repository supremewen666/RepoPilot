# Copy this file to `.env` and fill in the values you need.

# Optional: override the repository root used for indexing and local storage.
REPOPILOT_REPO_ROOT=/Users/supremewen/RepoPilot

# Optional: keep local indexes and fallback memory under a custom directory.
REPOPILOT_DATA_DIR=/Users/supremewen/RepoPilot/.repopilot
REPOPILOT_RAG_INDEX_PATH=/Users/supremewen/RepoPilot/.repopilot/rag_index.json
REPOPILOT_MEMORY_STORE_PATH=/Users/supremewen/RepoPilot/.repopilot/memory_store.json

# OpenAI-compatible model configuration.
REPOPILOT_MODEL=openai:gpt-4.1-mini
REPOPILOT_MODEL_NAME=gpt-4.1-mini
REPOPILOT_QUERY_MODEL_NAME=gpt-4.1-mini
REPOPILOT_EMBEDDING_MODEL_NAME=qwen3-embedding
REPOPILOT_RERANK_MODEL_NAME=qwen3-rerank

# Example DeepSeek-compatible setup:
# REPOPILOT_MODEL=openai:deepseek-chat
# REPOPILOT_MODEL_NAME=deepseek-chat

# Model provider credentials.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
REPOPILOT_QUERY_BASE_URL=
REPOPILOT_EMBEDDING_BASE_URL=
REPOPILOT_RERANK_BASE_URL=

# Example DeepSeek-compatible base URL:
# OPENAI_BASE_URL=https://api.deepseek.com

# Optional production RAG backend bundle.
# Set `REPOPILOT_RAG_STORAGE_BACKEND=postgres_qdrant` to enable it.
REPOPILOT_RAG_STORAGE_BACKEND=
REPOPILOT_POSTGRES_DSN=postgresql://user:password@localhost:5432/repopilot
REPOPILOT_QDRANT_URL=https://your-qdrant-host:6333
REPOPILOT_QDRANT_API_KEY=
REPOPILOT_QDRANT_COLLECTION_PREFIX=repopilot

# GitHub MCP configuration: local stdio mode via a repo-local wrapper script.
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
REPOPILOT_GITHUB_MCP_COMMAND=/Users/supremewen/RepoPilot/scripts/start_github_mcp.sh
REPOPILOT_GITHUB_MCP_ARGS=
REPOPILOT_GITHUB_MCP_ENV={"GITHUB_PERSONAL_ACCESS_TOKEN":"your_github_pat_here"}
REPOPILOT_GITHUB_MCP_URL=
REPOPILOT_GITHUB_MCP_HEADERS=
